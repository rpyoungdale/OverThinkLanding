{
  "cleanUrls": true,
  "buildCommand": "npm run build:legal",
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/privacy-policy",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/terms-of-use",
      "destination": "/terms",
      "permanent": true
    }
  ]
}
