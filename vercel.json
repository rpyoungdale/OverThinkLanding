{
  "cleanUrls": true,
  "buildCommand": "npm run build:legal",
  "outputDirectory": "public",
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "redirects": [
    {
      "source": "/privacy-policy",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/terms-of-use",
      "destination": "/terms",
      "permanent": true
    }
  ]
}
